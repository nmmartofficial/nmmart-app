<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Shimmer for Categories -->
    <View
        android:layout_width="120dp"
        android:layout_height="24dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">
        <include layout="@layout/item_shimmer_category" />
        <include layout="@layout/item_shimmer_category" />
        <include layout="@layout/item_shimmer_category" />
        <include layout="@layout/item_shimmer_category" />
    </LinearLayout>

    <!-- Shimmer for Section Title -->
    <View
        android:layout_width="150dp"
        android:layout_height="24dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp" />

    <!-- Shimmer for Horizontal Products -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">
        <include layout="@layout/item_shimmer_product_horizontal" />
        <include layout="@layout/item_shimmer_product_horizontal" />
    </LinearLayout>

    <!-- Shimmer for Section Title -->
    <View
        android:layout_width="180dp"
        android:layout_height="24dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp" />

    <!-- Shimmer for Product Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:alignmentMode="alignMargins">
        <include layout="@layout/item_shimmer_product" />
        <include layout="@layout/item_shimmer_product" />
        <include layout="@layout/item_shimmer_product" />
        <include layout="@layout/item_shimmer_product" />
    </GridLayout>

</LinearLayout>
